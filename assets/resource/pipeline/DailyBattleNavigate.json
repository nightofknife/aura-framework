{
    "DailyBattleNavigateStart": {
        "next": [
            "DailyBattleSelectCategory"
        ],
        "post_delay": 0,
        "pre_delay": 0
    },
    "DailyBattleSelectCategory": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    400,
                    500
                ],
                "order_by": "Expected",
                "expected": "干员养成"
            }
        },
        "action": "Click",
        "post_delay": 200,
        "next": [
            "DailyBattleSelectSubCategory"
        ]
    },
    "DailyBattleSelectSubCategory": {
        "recognition": {
            "type": "OCR",
            "param": {
                "order_by": "Expected",
                "expected": "干员进阶"
            }
        },
        "action": "DoNothing",
        "post_delay": 200,
        "next": [
            "DailyBattleFindGoTo"
        ]
    },
    "DailyBattleFindGoTo": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "DailyBattleSelectSubCategory",
                "roi_offset": [
                    400,
                    0,
                    550,
                    100
                ],
                "template": "AutoBattleFight/GoTo.png",
                "threshold": 0.8,
                "order_by": "Score"
            }
        },
        "action": "Click",
        "post_delay": 200,
        "on_error": [
            "DailyBattleScrollSubCategory"
        ],
        "next": [
            "DailyBattleSelectLevel",
            "DailyBattleSelectReward",
            "DailyBattleClickEnter"
        ]
    },
    "DailyBattleScrollSubCategory": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": "Swipe",
        "begin": [
            750,
            550
        ],
        "end": [
            750,
            250
        ],
        "post_wait_freezes": 200,
        "post_delay": 200,
        "max_hit": 3,
        "next": [
            "DailyBattleSelectSubCategory"
        ]
    },
