{
    "AutoBattleNavigateStart": {
        "next": [
            "AutoBattleSelectCategory"
        ],
        "post_delay": 0,
        "pre_delay": 0
    },
    "AutoBattleSelectCategory": {
        "recognition": {
            "type": "OCR",
            "param": {
                "roi": [
                    0,
                    0,
                    400,
                    500
                ],
                "order_by": "Expected",
                "expected": "[PLACEHOLDER]"
            }
        },
        "action": "Click",
        "post_delay": 200,
        "next": [
            "AutoBattleSelectSubCategory"
        ]
    },
    "AutoBattleSelectSubCategory": {
        "recognition": {
            "type": "OCR",
            "param": {
                "order_by": "Expected",
                "expected": "[PLACEHOLDER]"
            }
        },
        "action": "DoNothing",
        "post_delay": 200,
        "next": [
            "AutoBattleFindGoTo"
        ]
    },
    "AutoBattleFindGoTo": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": "AutoBattleSelectSubCategory",
                "roi_offset": [
                    400,
                    0,
                    550,
                    100
                ],
                "template": "AutoBattleFight/GoTo.png",
                "threshold": 0.8,
                "order_by": "Score"
            }
        },
        "action": "Click",
        "post_delay": 200,
        "on_error": [
            "AutoBattleScrollSubCategory"
        ],
        "next": [
            "AutoBattleSelectLevel",
            "AutoBattleSelectReward",
            "AutoBattleClickEnter"
        ]
    },
    "AutoBattleScrollSubCategory": {
        "recognition": {
            "type": "DirectHit"
        },
        "action": "Swipe",
        "begin": [
            750,
            550
        ],
        "end": [
            750,
            250
        ],
        "post_wait_freezes": 200,
        "post_delay": 200,
        "max_hit": 3,
        "next": [
            "AutoBattleSelectSubCategory"
        ]
    },
    "AutoBattleSelectLevel": {
        "recognition": {
            "type": "OCR",
            "param": {
                "order_by": "Expected",
                "expected": "[PLACEHOLDER]"
            }
        },
        "timeout": 2000,
        "action": "Click",
        "post_delay": 200,
        "next": [
            "AutoBattleSelectReward",
            "AutoBattleClickEnter"
        ]
    },
    "AutoBattleSelectReward": {
        "enabled": false,
        "recognition": {
            "type": "OCR",
            "param": {
                "order_by": "Expected",
                "expected": "[PLACEHOLDER]"
            }
        },
        "action": "Click",
        "post_delay": 200,
        "next": [
            "AutoBattleClickEnter"
        ]
    },
    "AutoBattleClickEnter": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "AutoBattleFight/enterBattleSpecV1.png",
                "threshold": 0.8,
                "order_by": "Score"
            }
        },
        "timeout": 4000,
        "action": "Click",
        "post_delay": 200,
        "next": [
            "AutoBattleClickEnterConfirm"
        ]
    },
    "AutoBattleClickEnterConfirm": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "AutoBattleFight/enterBattleSpecV2.png",
                "threshold": 0.8,
                "order_by": "Score"
            }
        },
        "timeout": 4000,
        "action": "Click",
        "post_delay": 200,
        "next": [
            "AutoBattleExecuteAction"
        ]
    },
    "AutoBattleExecuteAction": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "AutoBattleExecuteAction",
                "custom_action_param": {
                    "repeat_times": 1
                }
            }
        },
        "next": [
            "AutoBattleNavigateEnd"
        ]
    },
    "AutoBattleNavigateEnd": {
        "post_delay": 0,
        "pre_delay": 0
    }
}
